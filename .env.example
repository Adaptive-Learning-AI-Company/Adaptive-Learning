# Combined fallback template.
# Preferred setup: commit `.env.public`, keep real secrets in local `.env` or `.env.secret`.
# Render/Postgres is the default deployment path. Local SQLite is opt-in only.

OPENAI_API_KEY=replace-with-platform-openai-key
GOOGLE_API_KEY=replace-with-platform-gemini-key
EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USER=admin@adaptivetutor.ai
EMAIL_PASSWORD=replace-with-mailbox-password
PUBLIC_BASE_URL=https://adaptive-learning-ckcv.onrender.com
SECRET_KEY=replace-with-a-long-random-secret
PROFILE_SECRET_KEY=replace-with-a-second-long-random-secret
PROMO_CODE_HASH_SECRET=replace-with-a-third-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/dbname
# ALLOW_LOCAL_SQLITE=true

# Optional overrides for billing_config.json defaults. The admin UI can now switch the hosted
# teacher, verifier, and fast models at runtime; these env vars only change the startup default selection.
# OPENAI_MODEL=gpt-5-mini
# OPENAI_VERIFIER_MODEL=gpt-5-mini
# OPENAI_FAST_MODEL=gpt-5-mini
# OPENAI_MODEL_PRIORITY=true
# OPENAI_VERIFIER_MODEL_PRIORITY=true
# OPENAI_FAST_MODEL_PRIORITY=true
# OPENAI_MODEL_INPUT_PRICE_PER_1M=0.25
# OPENAI_MODEL_OUTPUT_PRICE_PER_1M=2.00
# OPENAI_VERIFIER_MODEL_INPUT_PRICE_PER_1M=0.25
# OPENAI_VERIFIER_MODEL_OUTPUT_PRICE_PER_1M=2.00
# OPENAI_FAST_MODEL_INPUT_PRICE_PER_1M=0.25
# OPENAI_FAST_MODEL_OUTPUT_PRICE_PER_1M=2.00
BILLING_ALLOW_PAST_DUE_ACCESS=false
ALLOW_OPEN_TUTORING_ACCESS=false
# BILLING_CURRENCY=usd
# PLAN_BYOK_MONTHLY_PRICE_CENTS=99
# PLAN_HOSTED_MONTHLY_PRICE_CENTS=499
# PLAN_HOSTED_MONTHLY_TUTOR_TURN_CAP=1200
# PLAN_HOSTED_MONTHLY_LLM_CALL_CAP=2500
# PLAN_HOSTED_MONTHLY_INPUT_TOKEN_CAP=5000000
# PLAN_HOSTED_MONTHLY_OUTPUT_TOKEN_CAP=750000
# PLAN_HOSTED_MONTHLY_COST_CAP_CENTS=250
ADMIN_USERNAMES=admin
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_ID_BYOK_MONTHLY=price_replace_byok_monthly
STRIPE_PRICE_ID_HOSTED_MONTHLY=price_replace_hosted_monthly
STRIPE_SUCCESS_URL=https://adaptive-learning-ckcv.onrender.com/billing/success
STRIPE_CANCEL_URL=https://adaptive-learning-ckcv.onrender.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://adaptive-learning-ckcv.onrender.com/billing/manage-return
