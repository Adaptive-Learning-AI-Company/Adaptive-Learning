# Do not commit real values. Keep them in `.env` or `.env.secret`,
# then copy the same values into Render Environment Variables.

OPENAI_API_KEY=replace-with-platform-openai-key
GOOGLE_API_KEY=replace-with-platform-gemini-key
EMAIL_PASSWORD=replace-with-mailbox-password
SECRET_KEY=replace-with-a-long-random-secret
PROFILE_SECRET_KEY=replace-with-a-second-long-random-secret
PROMO_CODE_HASH_SECRET=replace-with-a-third-long-random-secret
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
# DATABASE_URL=postgresql://user:password@host:5432/dbname
