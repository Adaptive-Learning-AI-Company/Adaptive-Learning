# Safe to commit. Copy these values into Render as needed.
# Render is the default backend target for the app.

EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USER=admin@adaptivetutor.ai
PUBLIC_BASE_URL=https://adaptive-learning-ckcv.onrender.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5500,http://localhost:5500,https://adaptive-learning-ckcv.onrender.com,https://adaptivetutor.ai,https://www.adaptivetutor.ai

BILLING_ALLOW_PAST_DUE_ACCESS=false
ALLOW_OPEN_TUTORING_ACCESS=false
ADMIN_USERNAMES=admin

# Stripe price IDs are environment-specific but not secret.
STRIPE_PRICE_ID_BYOK_MONTHLY=price_replace_byok_monthly
STRIPE_PRICE_ID_HOSTED_MONTHLY=price_replace_hosted_monthly
STRIPE_SUCCESS_URL=https://adaptive-learning-ckcv.onrender.com/billing/success
STRIPE_CANCEL_URL=https://adaptive-learning-ckcv.onrender.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://adaptive-learning-ckcv.onrender.com/billing/manage-return

# Optional non-secret overrides.
# The admin UI can now switch hosted teacher, verifier, and fast models at runtime;
# these env vars only set the startup default before an administrator saves a different selection.
# BILLING_CURRENCY=usd
# OPENAI_MODEL=gpt-5-mini
# OPENAI_VERIFIER_MODEL=gpt-5-mini
# OPENAI_FAST_MODEL=gpt-5-mini
# PLAN_BYOK_MONTHLY_PRICE_CENTS=99
# PLAN_HOSTED_MONTHLY_PRICE_CENTS=499
# PLAN_HOSTED_MONTHLY_TUTOR_TURN_CAP=1200
# PLAN_HOSTED_MONTHLY_LLM_CALL_CAP=2500
# PLAN_HOSTED_MONTHLY_INPUT_TOKEN_CAP=5000000
# PLAN_HOSTED_MONTHLY_OUTPUT_TOKEN_CAP=750000
# PLAN_HOSTED_MONTHLY_COST_CAP_CENTS=250
